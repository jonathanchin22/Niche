# ──────────────────────────────────────────────────────────────────
# boba app — environment variables
# Copy this to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ──────────────────────────────────────────────────────────────────

# Supabase — get these from your project's API settings
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here   # server-side only

# App identity — tells shared packages which app this is
NEXT_PUBLIC_APP_ID=boba

# Maps — MapLibre is free/open source. For Google Places autocomplete:
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=your_google_places_key_here

# Foursquare Places API — used server-side to search for nearby boba shops
# Get a free API key at https://developer.foursquare.com/
# Only needed for place search on the Log page; the app works without it.
FOURSQUARE_API_KEY=your_foursquare_api_key_here

# Optional: analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
