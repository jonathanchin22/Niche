# Copy this to .env.local and fill in your values
# These are the same values as apps/boba — same Supabase project

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_APP_ID=brew

# Foursquare Places API (free tier) — https://developer.foursquare.com
# Used for cafe search autocomplete. 1,000 req/day on the free plan.
NEXT_PUBLIC_FOURSQUARE_API_KEY=your_foursquare_api_key_here
